# Copy to .env and adjust. Loaded automatically via dotenv (server).

NODE_ENV=development
PORT=3000

# MySQL (required for scraping jobs, history, and CSV pipeline)
# Matches docker-compose.yml below when using local MySQL.
DATABASE_URL=mysql://root:localroot@127.0.0.1:3307/property_manager

# Session signing (any long random string for local use)
JWT_SECRET=change-me-to-a-long-random-string

# Manus / production OAuth (optional for local — use DEV_SKIP_AUTH instead)
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Optional: owner notifications after each scrape (omit locally)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional: Yelp Fusion — second business source (phone, URL); improves match rate vs OSM alone
# https://docs.developer.yelp.com/docs/fusion-intro
YELP_API_KEY=

# Optional: server-side size filter at scrape time (default: save all sizes; filter in the UI instead).
# SCRAPER_MIN_SQFT=100000
# Set to 0 to exclude unknown-size OSM rows when SCRAPER_MIN_SQFT is also set:
# SCRAPER_INCLUDE_UNKNOWN_SIZE=0

# Overpass defaults when the UI does not send a radius (city search, or legacy clients).
# ZIP searches from the scraper UI send radius in miles → converted to meters server-side.
# SCRAPER_OVERPASS_RADIUS_CITY_M=22000
# SCRAPER_OVERPASS_RADIUS_ZIP_M=9000
# SCRAPER_OVERPASS_MAX_ELEMENTS=500

# Max properties to run full enrichment on (site crawl + optional LoopNet/Bing)
# SCRAPER_WEB_ENRICH_MAX=25
# SCRAPER_ENRICH_MAX_URL_FETCHES=24
# SCRAPER_ENRICH_DISCOVER_BUDGET=20

# After: pnpm playwright:install — render JS-heavy pages for emails / phones / on-page LinkedIn links
# PLAYWRIGHT_ENRICH=1

# Optional: best-effort LoopNet listing search (enrichment only — not a full LoopNet index; ToS applies)
# Pair with PLAYWRIGHT_ENRICH=1 if axios gets empty pages or blocks.
# SCRAPER_LOOPNET_ENRICH=1

# Optional: Azure Bing Web Search v7 — https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
# BING_SEARCH_API_KEY=

# Optional: set to 0 only if you add real OAuth and want to disable anonymous fallback
# OPEN_ACCESS=1

# In development, all users see the same scrape history (avoids empty list when OAuth user ≠ local-dev user).
# Set to 1 only if you need per-user job isolation while running `pnpm dev` with OAuth configured.
# SCRAPER_ISOLATE_JOBS_BY_USER=1
